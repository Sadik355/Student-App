pipeline {
    agent {
        label "worker_node"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[
                        url: 'https://github.com/Sadik355/Student-App.git',
                        credentialsId: 'github_token'
                    ]]
                ])
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Deploy to Artifactory') {
            steps {
                configFileProvider([
                    configFile(
                        fileId: '3d627782-c2ae-489c-a33c-8a541245abd9',
                        variable: 'MAVEN_SETTINGS'
                    )
                ]) {
                    sh 'mvn deploy -s $MAVEN_SETTINGS'
                }
            }
        }
    }
}
